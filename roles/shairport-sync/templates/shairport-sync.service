[Unit]
Description=Shairport Sync AirPlay receiver
After=network-online.target pipewire.service avahi-daemon.service
Wants=network-online.target avahi-daemon.service

[Service]
ExecStart=/usr/bin/shairport-sync -o pa -a "{{ airplay_name | default('airplay-audio') }}" --use-stderr -v
Restart=always
RestartSec=5

[Install]
WantedBy=default.target