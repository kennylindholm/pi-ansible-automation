[Unit]
Description=Bluetooth auto-reconnect daemon
After=bluetooth.target

[Service]
ExecStart=/usr/bin/python3 /home/media/bt-reconnect.py
Restart=always
RestartSec=10
StandardOutput=append:/home/media/bt-reconnect.log
StandardError=append:/home/media/bt-reconnect.log

[Install]
WantedBy=default.target
